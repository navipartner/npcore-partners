### EFT Cloud Flow: Prepare → Start → Poll Status

# Step 1: Prepare EFT Payment (creates transaction request, resolves EFT method from self-service profile)
# Amount is optional - omit to use remaining sale balance

POST https://api.npretail.app/np659015/BC/CRONUS+International+Ltd./pos/sale/{{saleId}}/eft/prepare HTTP/1.1
x-npr-api-remote-type: crane
Authorization: Basic {{username}}:{{password}}
content-type: application/json

{
    "amount": 120.00
}

###

# Step 2: Start EFT Payment (sends request to Adyen cloud terminal, blocks until terminal responds)
# Use the transactionId returned from prepare

POST https://api.npretail.app/np659015/BC/CRONUS+International+Ltd./pos/sale/{{saleId}}/eft/{{transactionId}}/cloud/start HTTP/1.1
x-npr-api-remote-type: crane
Authorization: Basic {{username}}:{{password}}

###

# Step 3: Poll EFT Status (check transaction result - includes payment delta when successful)

GET https://api.npretail.app/np659015/BC/CRONUS+International+Ltd./pos/sale/{{saleId}}/eft/{{transactionId}}/cloud/status HTTP/1.1
x-npr-api-remote-type: crane
Authorization: Basic {{username}}:{{password}}

###

# Cancel EFT Transaction (fire-and-forget abort request to terminal)

POST https://api.npretail.app/np659015/BC/CRONUS+International+Ltd./pos/sale/{{saleId}}/eft/{{transactionId}}/cloud/cancel HTTP/1.1
x-npr-api-remote-type: crane
Authorization: Basic {{username}}:{{password}}